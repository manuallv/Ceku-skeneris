# Server
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:5173

# Upload and storage
MAX_UPLOAD_BYTES=10485760
LOCAL_STORAGE_DIR=storage

# Existing accounting database.
# Prefer DATABASE_URL when Hostinger or your existing app provides it.
# Example only: mysql://user:password@host:3306/database
DATABASE_URL=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false

# Never expose this to the browser.
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-5.5

# Migrations are intentionally opt-in because production DB schema must be inspected first.
ALLOW_ADDITIVE_MIGRATIONS=false
